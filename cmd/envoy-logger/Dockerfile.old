# Step 1: Build the binary
FROM golang:1.25-bookworm AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# Note: Building from the envoy logger path
RUN go build -ldflags="-s -w" -o envoy-logger ./cmd/envoy-logger

# Step 2: Run the binary
FROM debian:bookworm-slim
# Install CA certs so the app can talk to Enphase/Envoy over HTTPS
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
WORKDIR /root/
# Create data dir for the JWT token
RUN mkdir /data
COPY --from=builder /app/envoy-logger .

# Run with the persistent token path
CMD ["./envoy-logger", "startup", "--token", "/data/envoy.jwt"]
