    "panel-5": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "InfluxDB_Energy"
                    },
                    "group": "influxdb",
                    "kind": "DataQuery",
                    "spec": {
                      "query": "from(bucket: \"energy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop) \n  |> filter(fn: (r) => r[\"_measurement\"] == \"emeter\")\n  // Regex to catch both phases\n  |> filter(fn: (r) => r[\"alias\"] =~ /net-consumption-L[12]/)\n  |> filter(fn: (r) => r[\"_field\"] == \"PowerMW\")\n  // 1. Cast to float immediately\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) }))\n  // 2. Pivot/Group so L1 and L2 are in the same table\n  |> group(columns: [\"_time\"])\n  // 3. Sum the values across the phases for each timestamp\n  |> sum()\n  // 4. Group back to a single series for the graph\n  |> group()\n  // 5. Convert to kW and Yield\n  |> map(fn: (r) => ({ r with _value: r._value / 1000.0 }))\n  |> yield(name: \"house_power_kw\")"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "InfluxDB_Energy"
                    },
                    "group": "influxdb",
                    "kind": "DataQuery",
                    "spec": {
                      "query": "from(bucket: \"energy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"daikin_stats\")\n  |> filter(fn: (r) => r[\"_field\"] == \"deepcool_active\" or r[\"_field\"] == \"schedule_enabled\")\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({\n      r with _value: if exists r.deepcool_active then (if r.deepcool_active then 2.0 else 1.0)\n                     else (if exists r.schedule_enabled then (if r.schedule_enabled == false then 2.0 else 1.0) else 1.0)\n    }))\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: true)\n  |> fill(column: \"_value\", value: 1.0)\n  |> yield(name: \"status\")"
                    },
                    "version": "v0"
                  },
                  "refId": "B"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
