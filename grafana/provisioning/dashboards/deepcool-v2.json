    "panel-4": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "InfluxDB_Energy"
                    },
                    "group": "influxdb",
                    "kind": "DataQuery",
                    "spec": {
                      "query": "envoy = from(bucket: \"energy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r.alias =~ /total-consumption-L[12]/)\n  |> aggregateWindow(every: 10m, fn: mean, createEmpty: true)\n  |> fill(value: 0.0)\n  |> group(columns: [\"_time\"])\n  |> sum()\n  |> group()\n  |> set(key: \"_field\", value: \"e\")\n\nplugs = from(bucket: \"energy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"emeter\" and r._field == \"PowerMW\")\n  |> filter(fn: (r) => r.alias !~ /total-consumption|production|net-consumption/)\n  |> aggregateWindow(every: 10m, fn: mean, createEmpty: true)\n  |> fill(value: 0.0)\n  |> group(columns: [\"_time\"])\n  |> sum()\n  |> group()\n  |> set(key: \"_field\", value: \"p\")\n\nunion(tables: [envoy, plugs])\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({ _time: r._time, unaccounted_p: (float(v: r.e) - float(v: r.p)) / 1000.0 }))\n  |> keep(columns: [\"_time\", \"unaccounted_p\"])"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "InfluxDB_Energy"
                    },
                    "group": "influxdb",
                    "kind": "DataQuery",
                    "spec": {
                      "query": "from(bucket: \"daikin\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"daikin_stats\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temp_outdoor\")\n  |> aggregateWindow(every: 10m, fn: mean, createEmpty: true)\n  |> map(fn: (r) => ({ _time: r._time, outdoor_t: r._value }))\n  |> keep(columns: [\"_time\", \"outdoor_t\"])"
                    },
                    "version": "v0"
                  },
                  "refId": "B"
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "InfluxDB_Energy"
                    },
                    "group": "influxdb",
                    "kind": "DataQuery",
                    "spec": {
                      "query": "from(bucket: \"daikin\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"daikin_stats\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temp_indoor\")\n  |> aggregateWindow(every: 10m, fn: mean, createEmpty: true)\n  |> fill(value: 22.5)\n  |> map(fn: (r) => ({ \n      _time: r._time, \n      soc_val: (22.5 - float(v: r._value)) / (22.5 - 16.5) * 100.0 \n  }))\n  |> keep(columns: [\"_time\", \"soc_val\"])"
                    },
                    "version": "v0"
                  },
                  "refId": "C"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
