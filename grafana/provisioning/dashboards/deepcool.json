      "pluginVersion": "12.4.2",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB_Energy"
          },
          "query": "from(bucket: \"energy\")\n  |> range(start: -12h) \n  |> filter(fn: (r) => r[\"_measurement\"] == \"emeter\")\n  // Regex to catch both phases\n  |> filter(fn: (r) => r[\"alias\"] =~ /net-consumption-L[12]/)\n  |> filter(fn: (r) => r[\"_field\"] == \"PowerMW\")\n  // 1. Cast to float immediately\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) }))\n  // 2. Pivot/Group so L1 and L2 are in the same table\n  |> group(columns: [\"_time\"])\n  // 3. Sum the values across the phases for each timestamp\n  |> sum()\n  // 4. Group back to a single series for the graph\n  |> group()\n  // 5. Convert to kW and Yield\n  |> map(fn: (r) => ({ r with _value: r._value / 1000.0 }))\n  |> yield(name: \"house_power_kw\")",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB_Energy"
          },
          "query": "from(bucket: \"daikin\")\n  |> range(start: -12h)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"daikin_stats\")\n  |> filter(fn: (r) => r[\"_field\"] == \"schedule_enabled\")\n  // Force boolean to a float value of 1500.0 (On) or 0.0 (Off)\n  |> map(fn: (r) => ({ \n      r with _value: if r._value == true then 1500.0 else 0.0 \n  }))\n  |> yield(name: \"deepcool_status\")",
          "refId": "B"
        }
      ],
