        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB_Energy"
          },
          "query": "from(bucket: \"daikin\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"daikin_stats\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temp_outdoor\" or r[\"_field\"] == \"hum_outdoor\" or r[\"_field\"] == \"hum_indoor\" or r[\"_field\"] == \"temp_indoor\")\n  |> aggregateWindow(every: 5m, fn: mean, column: \"_value\")\n  |> yield(name: \"weather\")",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB_Energy"
          },
          "query": "from(bucket: \"energy\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"emeter\")\n  |> filter(fn: (r) => r[\"alias\"] =~ /net-consumption-L[12]/)\n  |> filter(fn: (r) => r[\"_field\"] == \"PowerMW\")\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) }))\n  |> aggregateWindow(every: 5m, fn: mean, column: \"_value\")\n  |> group(columns: [\"_time\"])\n  |> sum()\n  |> group()\n  |> map(fn: (r) => ({ r with _value: r._value / 1000.0 }))\n  |> yield(name: \"power_kw\")",
          "refId": "B"
        }
      ],
